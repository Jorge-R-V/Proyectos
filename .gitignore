# ==============================================================================
# .gitignore global para el repositorio multiproyecto
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Datos Sensibles y Credenciales (¡CRÍTICO!)
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
session_*
*.pem
*.key
credentials.json
client_secret.json
*.sqlite
*.sqlite3
*.db

# ------------------------------------------------------------------------------
# 2. Node.js / Entornos de JavaScript / TypeScript
# ------------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
build/
.npm/
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.eslintcache
*.local

# ------------------------------------------------------------------------------
# 3. Python (Scripts, Flask, Entornos Virtuales)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
.pytest_cache/

# ------------------------------------------------------------------------------
# 4. Archivos Específicos del Sistema Operativo (OS)
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ------------------------------------------------------------------------------
# 5. Configuración de IDEs y Editores
# ------------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ------------------------------------------------------------------------------
# 6. Datos extraídos / Csv (Archivos grandes o temporales)
# ------------------------------------------------------------------------------
*.csv
